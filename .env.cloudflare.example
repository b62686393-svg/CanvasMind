# ============================================================
# Cloudflare 部署环境配置
# ============================================================
# 本文件仅作参考。实际部署时通过 wrangler secret 注入敏感变量：
#   wrangler secret put CLOUDFLARE_API_TOKEN
#   wrangler secret put PROVIDER_CONFIG_SECRET
#   wrangler secret put STORAGE_CONFIG_SECRET
# 非敏感变量已在 wrangler.jsonc 的 vars 中声明。
# ============================================================

# ─── Cloudflare D1 数据库访问（必填，通过 secret 注入） ──────
# Cloudflare 账户 ID（dashboard 右下角可见）。
CLOUDFLARE_ACCOUNT_ID=your-account-id

# D1 数据库 ID（创建 D1 数据库后获得）。
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id

# 拥有 D1 读写权限的 API Token（Cloudflare > My Profile > API Tokens）。
# 所需权限：Account > D1 > Edit。
CLOUDFLARE_API_TOKEN=your-d1-api-token

# ─── 应用配置（非敏感项已在 wrangler.jsonc 声明） ───────────
# 前端访问后端的统一地址（部署后替换为 Worker 域名）。
VITE_API_BASE_URL=https://canvasmind.<your-subdomain>.workers.dev

# 允许浏览器访问来源。
CORS_ALLOWED_ORIGINS=https://canvasmind.<your-subdomain>.workers.dev

# ─── 加密密钥（必填，通过 secret 注入） ─────────────────────
# Provider 配置加密密钥。
PROVIDER_CONFIG_SECRET=please-change-this-provider-secret

# 对象存储配置加密密钥。
STORAGE_CONFIG_SECRET=please-change-this-storage-secret

# ─── 认证配置 ────────────────────────────────────────────────
AUTH_LOGIN_CODE_EXPIRE_MINUTES=5
AUTH_SESSION_EXPIRE_DAYS=30

# ─── Redis（可选，默认禁用） ────────────────────────────────
# 容器部署默认不启用 Redis。如需启用，使用外部 Redis（如 Upstash）。
REDIS_ENABLED=false
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=1

# ─── R2 对象存储（推荐用于文件上传持久化） ──────────────────
# 容器文件系统重启即丢失，建议配置 R2 作为上传目标。
# R2 与 S3 完全兼容，部署后在管理后台「对象存储配置」中添加：
#
#   Endpoint:  https://<account-id>.r2.cloudflarestorage.com
#   Region:    auto
#   Bucket:    your-r2-bucket-name
#   Access Key: R2 API Token 的 Access Key ID
#   Secret Key: R2 API Token 的 Secret Access Key
#   Domain:    https://<custom-domain> 或 https://pub-<id>.r2.dev
#
# 配置完成后，上传文件将自动写入 R2，不再依赖容器本地文件系统。

# ─── 数据迁移（仅迁移存量数据时使用） ───────────────────────
# 源 MySQL 数据库连接串（运行 scripts/migrate-mysql-to-d1.mjs 时使用）。
# MYSQL_SOURCE_URL=mysql://user:pass@host:3306/canana_mind
