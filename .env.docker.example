# 单端口模式：宿主机暴露端口，同时映射为容器内服务监听端口。
APP_PORT=5409

# 前端访问后端的统一地址。
VITE_API_BASE_URL=https://your-domain.com

# 容器内静态资源目录。
STATIC_DIST_DIR=/app/dist

# 容器内上传目录。
UPLOADS_DIR=/app/uploads

# 允许浏览器访问来源，多个值用逗号分隔。
CORS_ALLOWED_ORIGINS=https://your-domain.com

# 数据库配置（二选一）：
# 方式一：Cloudflare D1（推荐，生产环境）。设置以下三项后无需 DATABASE_URL。
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
# CLOUDFLARE_API_TOKEN=your-d1-api-token
#
# 方式二：本地 SQLite（仅自托管 Docker 时使用，容器重启数据不丢失需挂载卷）。
DATABASE_URL=file:./prisma/dev.db

# Provider 配置加密密钥。
PROVIDER_CONFIG_SECRET=please-change-this-provider-secret

# 对象存储配置加密密钥。
STORAGE_CONFIG_SECRET=please-change-this-storage-secret

# 登录验证码有效期（分钟）。
AUTH_LOGIN_CODE_EXPIRE_MINUTES=5

# 登录会话有效期（天）。
AUTH_SESSION_EXPIRE_DAYS=30

# Redis 基础配置（最小必填）
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_URL=

# Redis 高级配置（可选；不填会走默认值）
REDIS_PREFIX=canana
REDIS_ENV=production
REDIS_DEFAULT_TTL_SECONDS=60
REDIS_TASK_RUNTIME_TTL_SECONDS=1800
REDIS_TASK_SNAPSHOT_TTL_SECONDS=1800
REDIS_TASK_ABORT_TTL_SECONDS=300
REDIS_TASK_LOCK_TTL_MS=30000
